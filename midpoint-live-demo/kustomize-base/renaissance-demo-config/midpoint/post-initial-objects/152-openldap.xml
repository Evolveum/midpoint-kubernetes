<resource 
  xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3" 
  xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3" 
  xmlns:icfs="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/resource-schema-3" 
  xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3" 
  xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3" 
  xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3" 
  xmlns:t="http://prism.evolveum.com/xml/ns/public/types-3" 
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
  oid="ebd0bf7b-7e80-4175-ba5e-4fd5de2ecd62">
    <name>LDAP Server (OpenLDAP)</name>
    <description>LDAP resource using new LDAP Connector based on Apache Directory API. It contains configuration&amp;#13;
        for connecting to an OpenLDAP instance running on the localhost.</description>
	<connectorRef>
		<filter>
			<q:text>connectorType = "com.evolveum.polygon.connector.ldap.LdapConnector"</q:text>
		</filter>
	</connectorRef>
	<!-- in case of error (bug #9537) replace with
	<connectorRef oid="f2142752-c2a3-4e08-a872-604d38d3bbd0" relation="org:default" type="c:ConnectorType">
    </connectorRef>
    -->
    <connectorConfiguration xmlns:icfc="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/connector-schema-3">
        <icfc:configurationProperties xmlns:cfg="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/bundle/com.evolveum.polygon.connector-ldap/com.evolveum.polygon.connector.ldap.LdapConnector">
            <cfg:host><expression><const>LDAPADDRESS</const></expression></cfg:host>
            <cfg:port>389</cfg:port>
            <cfg:bindDn>cn=admin,dc=example,dc=com</cfg:bindDn>
            <cfg:bindPassword>
                <clearValue>secret</clearValue>
            </cfg:bindPassword>
            <cfg:baseContext>dc=example,dc=com</cfg:baseContext>
            <cfg:pagingStrategy>spr</cfg:pagingStrategy>
            <cfg:vlvSortAttribute>uid,cn,ou,dc</cfg:vlvSortAttribute>
            <cfg:vlvSortOrderingRule>2.5.13.3</cfg:vlvSortOrderingRule>
            <cfg:operationalAttributes>memberOf</cfg:operationalAttributes>
            <cfg:operationalAttributes>createTimestamp</cfg:operationalAttributes>
        </icfc:configurationProperties>
    </connectorConfiguration>
   <schema>
        <generationConstraints>
            <generateObjectClass>ri:inetOrgPerson</generateObjectClass>
            <generateObjectClass>ri:groupOfNames</generateObjectClass>
            <generateObjectClass>ri:organizationalUnit</generateObjectClass>
        </generationConstraints>
    </schema>
    <schemaHandling>
        <objectType>
            <kind>account</kind>
            <intent>default</intent>
            <displayName>Default Account</displayName>
            <default>true</default>
            <delineation>
                <objectClass>ri:inetOrgPerson</objectClass>
            </delineation>
            <focus>
                <type>UserType</type>
                <archetypeRef oid="00000000-0000-0000-0000-000000000702" relation="org:default" type="c:ArchetypeType">
                </archetypeRef>
            </focus>
			            <correlation>
                <correlators>
                    <items>
                        <name>Unique ID correlator</name>
                        <description>Exact match on name property</description>
                        <enabled>true</enabled>
                        <item>
                            <ref>name</ref>
                        </item>
                    </items>
                </correlators>
            </correlation>

            <synchronization>
                <reaction>
                    <name>linked-synchronize</name>
                    <situation>linked</situation>
                    <actions>
                        <synchronize/>
                    </actions>
                </reaction>
                <reaction>
                    <name>deleted-synchronize</name>
                    <situation>deleted</situation>
                    <actions>
                        <synchronize/>
                    </actions>
                </reaction>
                <reaction>
                    <name>unlinked-link</name>
                    <situation>unlinked</situation>
                    <actions>
                        <link/>
                    </actions>
                </reaction>
                <reaction>
                    <name>unmatched-addfocus</name>
                    <situation>unmatched</situation>
                    <actions>
                        <addFocus/>
                    </actions>
                </reaction>
            </synchronization>
            <attribute>
                <ref>ri:dn</ref>
                <displayName>Distinguished Name</displayName>
                <limitations>
                    <minOccurs>0</minOccurs>
                </limitations>
                <outbound>
                    <name>dn</name>
                    <source>
                        <path>$focus/name</path>
                    </source>
                    <expression>
                        <script>
                            <code>'uid=' + name + ',ou=people,dc=example,dc=com'</code>
                        </script>
                    </expression>
                </outbound>
            </attribute>
            <attribute>
                <ref>ri:entryUUID</ref>
                <displayName>Entry UUID</displayName>
                <limitations>
                    <access>
                        <read>true</read>
                    </access>
                </limitations>
            </attribute>
            <attribute>
                <ref>ri:cn</ref>
                <displayName>Common Name</displayName>
                <limitations>
                    <minOccurs>0</minOccurs>
                    <maxOccurs>1</maxOccurs>
                    <access>
                        <read>true</read>
                        <add>true</add>
                        <modify>true</modify>
                    </access>
                </limitations>
                <outbound>
                    <name>cn</name>
                    <source>
                        <path>$focus/fullName</path>
                    </source>
                </outbound>
                <inbound>
                    <name>fullName</name>
                    <strength>weak</strength>
                    <target>
                        <path>$focus/fullName</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:givenName</ref>
                <displayName>Given Name</displayName>
                <limitations>
                    <maxOccurs>1</maxOccurs>
                </limitations>
                <outbound>
                    <name>givenName</name>
                    <source>
                        <path>$focus/givenName</path>
                    </source>
                </outbound>
                <inbound>
                    <name>givenName</name>
                    <strength>weak</strength>
                    <target>
                        <path>$focus/givenName</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:sn</ref>
                <displayName>Surname</displayName>
                <limitations>
                    <minOccurs>0</minOccurs>
                    <maxOccurs>1</maxOccurs>
                </limitations>
                <outbound>
                    <name>sn</name>
                    <source>
                        <path>$focus/familyName</path>
                    </source>
                </outbound>
                <inbound>
                    <name>familyName</name>
                    <strength>weak</strength>
                    <target>
                        <path>$focus/familyName</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:uid</ref>
                <displayName>Login Name</displayName>
                <limitations>
                    <maxOccurs>1</maxOccurs>
                    <access>
                        <read>true</read>
                        <add>true</add>
                    </access>
                </limitations>
                <outbound>
                    <name>uid</name>
                    <strength>weak</strength>
                    <source>
                        <path>$focus/name</path>
                    </source>
                </outbound>
                <inbound>
                    <name>name</name>
                    <strength>weak</strength>
                    <target>
                        <path>$focus/name</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:description</ref>
                <limitations>
                    <maxOccurs>1</maxOccurs>
                </limitations>
                <outbound>
                    <name>description</name>
                    <strength>weak</strength>
                    <expression>
                        <description>Expression that assigns a fixed description value if there is no other description present.</description>
                        <value>Managed by midPoint</value>
                    </expression>
                </outbound>
            </attribute>
            <attribute>
                <ref>ri:l</ref>
                <inbound>
                    <name>locality</name>
                    <target>
                        <path>$focus/locality</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:telephoneNumber</ref>
                <outbound>
                    <name>telephoneNumber</name>
                    <source>
                        <path>$focus/telephoneNumber</path>
                    </source>
                </outbound>
                <inbound>
                    <name>telephoneNumber</name>
                    <target>
                        <path>$focus/telephoneNumber</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:employeeNumber</ref>
                <outbound>
                    <name>employeeNumber</name>
                    <strength>strong</strength>
                    <source>
                        <path>$focus/personalNumber</path>
                    </source>
                </outbound>
                <inbound>
                    <name>personalNumber</name>
                    <strength>weak</strength>
                    <target>
                        <path>$focus/personalNumber</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>mail</ref>
                <outbound>
                    <name>Email address</name>
                    <lifecycleState>proposed</lifecycleState>
                    <strength>strong</strength>
                    <source>
                        <path>emailAddress</path>
                    </source>
                    <target>
                        <set>
                            <predefined>all</predefined>
                        </set>
                    </target>
                </outbound>
            </attribute>
            <attribute>
                <ref>ri:employeeType</ref>
                <limitations>
                    <maxOccurs>1</maxOccurs>
                </limitations>
                <inbound>
                    <name>Archetype by name</name>
                    <strength>weak</strength>
                    <expression>
                        <assignmentTargetSearch>
                            <targetType>ArchetypeType</targetType>
                            <filter>
                                <q:text>name = $input</q:text>
                            </filter>
                        </assignmentTargetSearch>
                    </expression>
                    <target>
                        <path>assignment</path>
                    </target>
                    <condition>
                        <script>
                            <code>input != null</code>
                        </script>
                    </condition>
                </inbound>
            </attribute>
            <marking>
                <markRef oid="00000000-0000-0000-0000-000000000800" type="c:MarkType"/>
                <pattern>
                    <filter>
                        <q:text>
                            attributes/ri:dn = "cn=idm,ou=Administrators,dc=example,dc=com"
                        </q:text>
                    </filter>
                </pattern>
            </marking>
            <activation>
                <administrativeStatus>
                    <outbound/>
                    <inbound>
                        <strength>weak</strength>
                        <expression>
                            <asIs/>
                        </expression>
                    </inbound>
                </administrativeStatus>
            </activation>
            <credentials>
                <password>
                    <outbound>
                        <expression>
                            <asIs/>
                        </expression>
                    </outbound>
                    <inbound>
                        <strength>weak</strength>
                        <expression>
                            <generate/>
                        </expression>
                    </inbound>
                </password>
            </credentials>
        </objectType>
        <objectType>
            <kind>generic</kind>
            <intent>ou</intent>
            <displayName>Organizational Unit</displayName>
            <delineation>
                <objectClass>ri:organizationalUnit</objectClass>
            </delineation>
            <focus>
                <type>OrgType</type>
            </focus>
            <correlation>
                <correlators>
                    <items>
                        <name>Unique ID correlator</name>
                        <description>Exact match on name property</description>
                        <enabled>true</enabled>
                        <item>
                            <ref>name</ref>
                        </item>
                    </items>
                </correlators>
            </correlation>
            <synchronization>
                <reaction>
                    <name>linked-synchronize</name>
                    <situation>linked</situation>
                    <actions>
                        <synchronize/>
                    </actions>
                </reaction>
                <reaction>
                    <name>deleted-synchronize</name>
                    <situation>deleted</situation>
                    <actions>
                        <synchronize/>
                    </actions>
                </reaction>
                <reaction>
                    <name>unlinked-link</name>
                    <situation>unlinked</situation>
                    <actions>
                        <link/>
                    </actions>
                </reaction>
            </synchronization>
            <attribute>
                <ref>ri:dn</ref>
                <matchingRule xmlns:gen868="http://prism.evolveum.com/xml/ns/public/matching-rule-3">gen868:stringIgnoreCase</matchingRule>
                <outbound>
                    <name>dn</name>
                    <source>
                        <path>$focus/name</path>
                    </source>
                    <expression>
                        <script>
                            <code>
                                import javax.naming.ldap.Rdn
                                import javax.naming.ldap.LdapName
                                import com.evolveum.midpoint.xml.ns._public.common.common_3.*;

                                dn = new LdapName('ou=Orgs,dc=example,dc=com')
                                parents = new ArrayList()
                                currentOrg = focus
                                while (currentOrg != null) {
                                parents.add(currentOrg)
                                // see com.evolveum.midpoint.model.impl.expr.MidpointFunctionsImpl
                                currentOrg = midpoint.getParentOrgByOrgType(currentOrg, 'functional')
                                }

                                log.info("parents = {}", parents)

                                for (int i = parents.size() -1 ; i &gt;= 0; i--) {
                                dn.add(new Rdn('ou', parents.get(i).name.toString()))
                                }

                                log.info("dn = {}", dn)

                                return dn.toString();
                            </code>
                        </script>
                    </expression>
                </outbound>
            </attribute>
            <attribute>
                <ref>ri:ou</ref>
                <matchingRule xmlns:gen868="http://prism.evolveum.com/xml/ns/public/matching-rule-3">gen868:stringIgnoreCase</matchingRule>
                <inbound>
                    <name>dn-to-name</name>
                    <target>
                        <path>name</path>
                    </target>
                    <use>correlation</use>
                </inbound>
            </attribute>
        </objectType>
        <objectType>
            <kind>entitlement</kind>
            <intent>group</intent>
            <displayName>Group</displayName>
            <default>true</default>
            <delineation>
                <objectClass>ri:groupOfNames</objectClass>
            </delineation>
        </objectType>
        <objectType>
            <kind>entitlement</kind>
            <intent>ldapProject</intent>
            <displayName>LDAP project groups</displayName>
            <delineation>
                <objectClass>ri:groupOfNames</objectClass>
            </delineation>
            <focus>
                <type>OrgType</type>
            </focus>
            <correlation>
                <correlators>
                    <items>
                        <name>Unique ID correlator</name>
                        <description>Exact match on name property</description>
                        <enabled>true</enabled>
                        <item>
                            <ref>name</ref>
                        </item>
                    </items>
                </correlators>
            </correlation>
            <synchronization>
                <reaction>
                    <name>linked-synchronize</name>
                    <situation>linked</situation>
                    <actions>
                        <synchronize/>
                    </actions>
                </reaction>
                <reaction>
                    <name>deleted-synchronize</name>
                    <situation>deleted</situation>
                    <actions>
                        <synchronize/>
                    </actions>
                </reaction>
                <reaction>
                    <name>unlinked-link</name>
                    <situation>unlinked</situation>
                    <actions>
                        <link/>
                    </actions>
                </reaction>
            </synchronization>
            <attribute>
                <ref>ri:dn</ref>
                <matchingRule xmlns:gen868="http://prism.evolveum.com/xml/ns/public/matching-rule-3">gen868:stringIgnoreCase</matchingRule>
                <outbound>
                    <name>dn</name>
                    <source>
                        <path>$focus/name</path>
                    </source>
                    <expression>
                        <script>
                            <code>
                                import javax.naming.ldap.Rdn
                                import javax.naming.ldap.LdapName

                                dn = new LdapName('ou=Projects,dc=example,dc=com')
                                dn.add(new Rdn('cn', name.toString()))
                                return dn.toString()
                            </code>
                        </script>
                    </expression>
                </outbound>
            </attribute>
            <attribute>
                <ref>ri:cn</ref>
                <matchingRule xmlns:gen868="http://prism.evolveum.com/xml/ns/public/matching-rule-3">gen868:stringIgnoreCase</matchingRule>
                <outbound>
                    <name>cn</name>
                    <strength>weak</strength>
                    <source>
                        <path>$focus/name</path>
                    </source>
                </outbound>
                <inbound>
                    <name>cn-to-name</name>
                    <target>
                        <path>name</path>
                    </target>
                    <use>correlation</use>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:entryUUID</ref>
                <matchingRule xmlns:gen868="http://prism.evolveum.com/xml/ns/public/matching-rule-3">gen868:stringIgnoreCase</matchingRule>
            </attribute>
            <attribute>
                <ref>ri:description</ref>
                <outbound>
                    <name>description</name>
                    <source>
                        <path>description</path>
                    </source>
                </outbound>
            </attribute>
            <attribute>
                <ref>ri:member</ref>
                <matchingRule xmlns:gen868="http://prism.evolveum.com/xml/ns/public/matching-rule-3">gen868:distinguishedName</matchingRule>
                <outbound>
                    <name>member</name>
                    <strength>weak</strength>
                    <expression>
                        <value>uid=nobody,dc=nothing</value>
                    </expression>
                </outbound>
            </attribute>
        </objectType>
        <associationType>
            <name>groupMembership</name>
            <displayName>LDAP Group Membership</displayName>
            <subject>
                <objectType>
                    <kind>account</kind>
                    <intent>default</intent>
                </objectType>
                <association>
                    <ref>ri:ldapGroups</ref>
                    <sourceAttributeRef>ri:ldapGroups</sourceAttributeRef>
                </association>
            </subject>
            <object>
                <objectType>
                    <kind>entitlement</kind>
                    <intent>group</intent>
                </objectType>
                <objectType>
                    <kind>entitlement</kind>
                    <intent>ldapProject</intent>
                </objectType>
            </object>
        </associationType>
    </schemaHandling>
    <capabilities>
        <native xmlns:cap="http://midpoint.evolveum.com/xml/ns/public/resource/capabilities-3">
            <cap:schema/>
            <cap:credentials>
                <cap:password>
                    <cap:returnedByDefault>false</cap:returnedByDefault>
                </cap:password>
            </cap:credentials>
            <cap:liveSync/>
            <cap:create/>
            <cap:read>
                <cap:returnDefaultAttributesOption>true</cap:returnDefaultAttributesOption>
            </cap:read>
            <cap:update>
                <cap:delta>true</cap:delta>
                <cap:addRemoveAttributeValues>true</cap:addRemoveAttributeValues>
            </cap:update>
            <cap:delete/>
            <cap:testConnection/>
            <cap:script>
                <cap:host>
                    <cap:type>connector</cap:type>
                </cap:host>
            </cap:script>
            <cap:pagedSearch/>
            <cap:auxiliaryObjectClasses/>
        </native>
        <configured xmlns:cap="http://midpoint.evolveum.com/xml/ns/public/resource/capabilities-3">
            <cap:references>
                <cap:enabled>true</cap:enabled>
                <cap:type>
                    <cap:name>ri:groupMembership</cap:name>
                    <cap:subject>
                        <cap:delineation>
                            <cap:objectClass>ri:inetOrgPerson</cap:objectClass>
                        </cap:delineation>
                        <cap:primaryBindingAttributeRef>ri:dn</cap:primaryBindingAttributeRef>
                        <cap:localItemName>ri:ldapGroups</cap:localItemName>
                    </cap:subject>
                    <cap:object>
                        <cap:delineation>
                            <cap:objectClass>ri:groupOfNames</cap:objectClass>
                        </cap:delineation>
                        <cap:primaryBindingAttributeRef>ri:member</cap:primaryBindingAttributeRef>
                    </cap:object>
                    <cap:direction>objectToSubject</cap:direction>
                    <cap:explicitReferentialIntegrity>false</cap:explicitReferentialIntegrity>
                </cap:type>
            </cap:references>
        </configured>
    </capabilities>
</resource>
